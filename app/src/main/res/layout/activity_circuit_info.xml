<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="24dp">

    <TextView
        android:id="@+id/text_description_circuit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="🎯 Dans ce jeu, créez d'abord les éléments :
• 1er toucher ➜ Objectif 🎯
• 2e toucher ➜ Bille ⚪
• Tous les suivants ➜ Obstacles 🚧

➡ Une fois la bille créée, inclinez votre appareil pour la faire rouler.
🏁 Si elle atteint l'objectif, vous gagnez !
💥 Si elle touche un obstacle, la partie est perdue et relancée automatiquement."
        android:textSize="16sp"
        android:textColor="#333"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/button_jouer_circuit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jouer"
        app:layout_constraintTop_toBottomOf="@id/text_description_circuit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <Button
        android:id="@+id/button_retour_circuit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Retour"
        app:layout_constraintTop_toBottomOf="@id/button_jouer_circuit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>