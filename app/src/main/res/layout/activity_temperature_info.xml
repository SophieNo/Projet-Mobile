<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/text_description_temp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/info_temperature_game"
        android:textSize="18sp"
        android:padding="8dp"
        android:textColor="#333"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Meilleur score -->
    <TextView
        android:id="@+id/text_best_score_temp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Meilleur score : 0"
        android:textSize="16sp"
        android:textColor="#333333"
        android:textAlignment="center"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/text_description_temp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bouton Jouer -->
    <Button
        android:id="@+id/button_jouer_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/play"
        app:layout_constraintTop_toBottomOf="@id/text_best_score_temp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- Bouton Retour -->
    <Button
        android:id="@+id/button_retour_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/back"
        app:layout_constraintTop_toBottomOf="@id/button_jouer_temp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>