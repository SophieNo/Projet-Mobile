<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/text_description_temp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="🌡️ Dans ce jeu, une ville est tirée au sort (ex. Paris), et votre localisation est détectée.

Votre objectif est de deviner la différence de température entre votre position actuelle et celle de la ville choisie.

• Vous avez 3 essais.
• Au 3e essai, un indice est donné (ville ou température).
• Si vous trouvez la bonne différence, vous gagnez ! Sinon, une réponse s’affiche et vous pouvez rejouer."
        android:textSize="16sp"
        android:textColor="#333"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/button_jouer_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jouer"
        app:layout_constraintTop_toBottomOf="@id/text_description_temp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <Button
        android:id="@+id/button_retour_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Retour"
        app:layout_constraintTop_toBottomOf="@id/button_jouer_temp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>