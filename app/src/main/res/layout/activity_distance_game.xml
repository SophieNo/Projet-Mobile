<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Description du jeu -->
    <TextView
        android:id="@+id/text_instruction_distance"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/guess_distance_instruction"
        android:textSize="18sp"
        android:textColor="#333333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Ville tirée -->
    <TextView
        android:id="@+id/text_ville_distance"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/city_drawn_label"
        android:textSize="16sp"
        android:textColor="#555555"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/text_instruction_distance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.gms.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="200dp"
        app:layout_constraintTop_toBottomOf="@id/text_ville_distance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>


    <!-- Champ de saisie -->
    <EditText
        android:id="@+id/input_distance"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/enter_distance_hint"
        android:inputType="number"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/text_ville_distance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bouton Valider -->
    <Button
        android:id="@+id/button_submit_distance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/valider"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/input_distance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bouton Retour -->
    <Button
        android:id="@+id/button_retour_distance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/back"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/button_submit_distance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
